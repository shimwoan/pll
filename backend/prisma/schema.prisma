generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Case {
  id           String    @id @default(cuid())
  caseNumber   String    @unique
  claimNumbers String[]
  clientName   String
  handler      String
  stage        String    @default("Claim")
  dateOfLoss   DateTime?
  dueDate      DateTime?
  emails       Email[]
  createdAt    DateTime  @default(now())
}

model Email {
  id             String      @id @default(cuid())
  messageId      String      @unique
  subject        String
  bodyPreview    String
  body           String?
  fromAddress    String
  fromName       String
  toAddress      String
  receivedAt     DateTime

  aiCategory     String?
  aiConfidence   Float?
  aiReason       String?
  actionCategory String?
  aiSummary      String?
  finalCategory  String?
  workTypeTitle  String?

  matchedCaseId  String?
  matchMethod    String?
  case           Case?       @relation(fields: [matchedCaseId], references: [id])

  status         EmailStatus @default(PENDING_REVIEW)
  reviewedBy     String?
  reviewedAt     DateTime?

  webLink        String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model UserToken {
  id           String   @id @default(cuid())
  userEmail    String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum EmailStatus {
  PENDING_REVIEW
  CONFIRMED
  EDITED
  UNCLASSIFIED
}
